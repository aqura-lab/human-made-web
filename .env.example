# ─── Database (Neon / Vercel Postgres in prod) ───────────────────────────────
# Pooled connection string used at runtime.
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"
# Direct (non-pooled) connection used by `prisma migrate deploy`.
DIRECT_URL="postgres://user:pass@host/db?sslmode=require"

# ─── Auth / sessions ─────────────────────────────────────────────────────────
# 32+ byte random string. Generate: openssl rand -base64 32
JWT_SECRET=""
# Absolute base URL — used to build magic-link callbacks.
APP_URL="https://earlyaccess.humanmade.app"

# ─── Email (magic links) ─────────────────────────────────────────────────────
# Resend API key. If empty, links are logged to the server console (dev only).
RESEND_API_KEY=""
EMAIL_FROM="Human Made <hello@humanmade.app>"

# ─── Admin allowlist (comma-separated, lowercased) ───────────────────────────
ADMIN_EMAILS="alberto@aqurastudio.com"

# ─── Referral tuning ─────────────────────────────────────────────────────────
REFERRAL_GOAL="5"
REFERRAL_BOOST_PER_CONVERSION="10"

# ─── Cron protection ─────────────────────────────────────────────────────────
# Vercel Cron sends `Authorization: Bearer $CRON_SECRET` automatically.
# Generate: openssl rand -base64 32
CRON_SECRET=""

# ─── Vercel Blob (desktop app DMG storage) ───────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"
