// Human Made — early-access platform data model.
// Privacy-first: stores only signup + queue + referral + feedback metadata.
// No raw draft text or keystroke data ever lives here (that stays on-device in
// the desktop app); the certificate verifier is stateless and persists nothing.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id     String  @id @default(cuid())
  email  String  @unique // stored lowercased
  name   String
  reason String? // "why you want early access" free text

  // --- Consent (double opt-in / GDPR) ---
  consentGdpr    Boolean   @default(false)
  consentTerms   Boolean   @default(false)
  consentPrivacy Boolean   @default(false)
  consentAt      DateTime?
  consentIp      String?
  consentUA      String?

  // --- Email verification (second opt-in) ---
  emailVerified DateTime?

  // --- Password auth (optional; magic link always works) ---
  passwordHash     String? // scrypt-encoded; null = magic-link-only
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?

  // --- Queue / priority ---
  createdAt     DateTime @default(now()) // base FIFO ordering key
  priorityBoost Int      @default(0) // sum of bumps from converted referrals
  // effective queue order = (priorityBoost DESC, createdAt ASC)

  // --- Referral (self-relation) ---
  referralCode String  @unique
  referredById String?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals    User[]  @relation("Referrals")

  // --- Perks (private, derived; persisted when unlocked) ---
  perkFreeYearGranted Boolean @default(false)

  downloadReleasedAt DateTime? // admin unlocks the desktop download for this user

  // --- GDPR soft-delete ---
  deletedAt DateTime?

  feedback     Feedback[]
  votes        FeedbackVote[]
  magicTokens  MagicLinkToken[]
  certificates Certificate[]

  @@index([priorityBoost(sort: Desc), createdAt(sort: Asc)])
  @@index([referredById])
  @@index([emailVerified])
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique // sha256(rawToken); raw token never stored
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime? // single-use: set on first consume
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Feedback {
  id         String         @id @default(cuid())
  userId     String? // nullable so anonymized rows survive account deletion
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  body       String
  tag        FeedbackTag
  anonymized  Boolean        @default(false)
  status      FeedbackStatus @default(NEW)
  public      Boolean        @default(false) // admin-promoted to the community board
  publicTitle String? // clean public label set by admin on promotion
  promotedAt  DateTime?
  votes       FeedbackVote[]
  createdAt   DateTime       @default(now())

  @@index([tag])
  @@index([status])
  @@index([createdAt])
  @@index([public])
}

enum FeedbackTag {
  UX
  ETHICS
  BUGS
}

enum FeedbackStatus {
  NEW
  REVIEWED
  HIDDEN
}

model FeedbackVote {
  id         String   @id @default(cuid())
  feedbackId String
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([feedbackId, userId])
  @@index([feedbackId])
}

model Release {
  id        String   @id @default(cuid())
  version   String
  fileName  String
  blobUrl   String
  sizeBytes Int?
  sha256    String?
  notes     String?
  isCurrent Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isCurrent])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// A certificate a writer has chosen to publish behind a public /c/[id] badge link.
// Stores ONLY the already-public signed JSON (no raw text/keystrokes). The stored
// payload is a cache for display — every render re-verifies the signature.
model Certificate {
  id          String   @id // the certificate's own signed UUID = the public handle
  signedJson  String // the already-public signed certificate JSON, stored verbatim
  articleUrl  String?
  userId      String? // publisher; nulled when they delete their account
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  publishedAt DateTime @default(now())

  @@index([userId])
}
